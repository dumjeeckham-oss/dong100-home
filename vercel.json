{
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/content/:path*", "destination": "/content/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "trailingSlash": true
}
